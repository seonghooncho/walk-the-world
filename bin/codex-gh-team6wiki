#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

WORKDIR="${TEAM6WIKI_DIR:-$ROOT_DIR/../6-team-team6-wiki}"
REPO="${TEAM6WIKI_REPO:-100-hours-a-week/6-team-team6-wiki}"

exec "$ROOT_DIR/bin/codex-gh" -C "$WORKDIR" -R "$REPO" "$@"
